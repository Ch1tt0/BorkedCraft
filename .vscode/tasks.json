{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "delete_assets",
      "command": "rm",
      "args": ["-rf", "${cwd}/target/debug/assets"],
      "type": "shell"
    },
    {
      "label": "update_assets",
      "dependsOn": ["delete_assets"],
      "command": "cp",
      "args": ["-r", "${cwd}/assets", "${cwd}/target/debug/assets"],
      "type": "shell"
    }
  ]
}
